# OpenRouter API key — get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override the default model (defaults to meta-llama/llama-3.3-70b-instruct:free)
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Your site URL (used as HTTP-Referer for OpenRouter)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
