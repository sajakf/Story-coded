# OpenRouter API key — get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override the default model (defaults to google/gemini-2.0-flash-001)
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Your site URL (used as HTTP-Referer for OpenRouter)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
