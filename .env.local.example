# OpenRouter API key — get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: override the default model (defaults to google/gemini-flash-1.5)
OPENROUTER_MODEL=google/gemini-flash-1.5

# Your site URL (used as HTTP-Referer for OpenRouter)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ElevenLabs text-to-speech — get yours at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
